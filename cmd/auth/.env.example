# Server
PORT=:9876
HTML_PATH=assets/*.html
COOKIE_SECURE=false # set true when served over HTTPS in production

# JWT
PRIVATE_KEY_PATH=cmd/auth/.secret/private_key.pem
PUBLIC_KEY_PATH=cmd/auth/.secret/public_key.pem
JWT_KID=hexagonal_architecture
JWT_ISSUER=http://host.docker.internal:9876
OAUTH_CLIENT_REDIRECT_WHITELIST=my_client http://localhost:3000/callback,https://test.example.com/callback;smoke-client https://app.example.com/callback
OAUTH_POST_LOGOUT_REDIRECT_ALLOWLIST=http://localhost:3000

# Repository
FILE_DIR=tmp
REPOSITORY_USED=file
USER_FILE_PATH=user.json

# MongoDB
MONGO_HOST=127.0.0.1:27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_DATABASE=

# Redis (optional — comment out to use in-memory cache)
# REDIS_ADDR=127.0.0.1:6379
# REDIS_DB=0

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@auth.local
APP_BASE_URL=http://localhost:3000