# Server
PORT=:9876
HTML_PATH=assets/*.html
COOKIE_SECURE=false # set true when served over HTTPS in production

# JWT
PRIVATE_KEY_PATH=cmd/auth/.secret/private_key.pem
PUBLIC_KEY_PATH=cmd/auth/.secret/public_key.pem
JWT_KID=hexagonal_architecture
JWT_ISSUER=http://host.docker.internal:9876
# OAuth client (single registered client until a persistent client registry lands)
# Required: the server panics at startup when no client is configured,
# unless DEV_SEED=true opts into the built-in development client.
# DEV_SEED=true
OAUTH_CLIENT_ID=my_client
OAUTH_CLIENT_REDIRECT_URIS=http://localhost:3000/callback,https://test.example.com/callback
# OAUTH_CLIENT_AUTH_METHOD=none # none | client_secret_basic | client_secret_post
# OAUTH_CLIENT_SECRET= # required when auth method is not "none"
# OAUTH_CLIENT_ALLOWED_GRANTS=authorization_code,refresh_token,password,client_credentials
# For the k6 smoke suite, restart with: OAUTH_CLIENT_ID=smoke-client OAUTH_CLIENT_REDIRECT_URIS=https://app.example.com/callback
OAUTH_POST_LOGOUT_REDIRECT_ALLOWLIST=http://localhost:3000

# Repository
FILE_DIR=tmp
REPOSITORY_USED=file
USER_FILE_PATH=user.json

# MongoDB
MONGO_HOST=127.0.0.1:27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_DATABASE=

# Redis (optional — comment out to use in-memory cache)
# REDIS_ADDR=127.0.0.1:6379
# REDIS_DB=0

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@auth.local
APP_BASE_URL=http://localhost:3000